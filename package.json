{
  "name": "unisalon",
  "private": true,
  "version": "0.0.1",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "turbo": "^2.5.3",
    "typescript": "^5.9.3",
    "prettier": "^3.5.3",
    "@types/bun": "^1.3.14"
  }
}
